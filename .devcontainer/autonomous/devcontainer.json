{
  "name": "Claude Code Sandbox (Autonomous)",
  "build": {
    "dockerfile": "../Dockerfile",
    "args": {
      "TZ": "${localEnv:TZ:America/Los_Angeles}",
      "CLAUDE_CODE_VERSION": "latest",
      "CLAUDE_THEME": "${localEnv:CLAUDE_THEME:dark-daltonized}"
    }
  },
  "runArgs": [
    "--cap-add=NET_ADMIN",
    "--cap-add=NET_RAW"
  ],
  "remoteUser": "node",
  "mounts": [
    "source=claude-code-bashhistory-${localEnv:DCO_PROJECT_ID:default},target=/commandhistory,type=volume",
    "source=claude-code-config-${localEnv:DCO_PROJECT_ID:default},target=/home/node/.claude,type=volume",
    "source=${localWorkspaceFolder}/.devcontainer/autonomous/CLAUDE.md,target=/home/node/.claude/CLAUDE.md,type=bind,readonly",
    "source=${localWorkspaceFolder}/.devcontainer/autonomous/settings.json,target=/home/node/.claude/settings.json,type=bind,readonly",
    "source=${localWorkspaceFolder}/.devcontainer/autonomous/allowlist.txt,target=/usr/local/etc/dco-allowlist.txt,type=bind,readonly"
  ],
  "containerEnv": {
    "NODE_OPTIONS": "--max-old-space-size=4096",
    "CLAUDE_CONFIG_DIR": "/home/node/.claude",
    "GH_TOKEN": "${localEnv:DCO_GITHUB_TOKEN}"
  },
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind,consistency=delegated",
  "workspaceFolder": "/workspace",
  "postStartCommand": "sudo /usr/local/bin/init-firewall.sh && gh auth setup-git",
  "waitFor": "postStartCommand"
}
