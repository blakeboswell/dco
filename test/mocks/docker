#!/usr/bin/env bash
# fake `docker` for tests — logs every invocation to $MOCK_LOG and returns
# canned output/exit codes controlled via MOCK_DOCKER_* env vars, so CLI
# tests can exercise dco's docker-calling code paths without a real daemon
set -euo pipefail

echo "docker $*" >> "${MOCK_LOG:-/dev/null}"

if [[ "$1" == "ps" ]]; then
  for arg in "$@"; do
    if [[ "$arg" == "-q" || "$arg" == "-aq" ]]; then
      # real `docker ps -q` with no matches emits zero bytes, not a blank
      # line -- matters because `mapfile` (unlike `$(...)`) treats a lone
      # blank line as one empty-string element, not an empty array
      [[ -n "${MOCK_DOCKER_CONTAINER_ID:-}" ]] && printf '%s\n' "$MOCK_DOCKER_CONTAINER_ID"
      exit 0
    fi
  done
  echo "NAMES  STATUS  FOLDER"
  exit 0
fi

if [[ "$1" == "rm" ]]; then
  exit "${MOCK_DOCKER_RM_EXIT:-0}"
fi

if [[ "$1" == "volume" ]]; then
  case "$2" in
    inspect)
      # MOCK_DOCKER_VOLUMES is a space-separated list of volume names that
      # "exist" for this test; anything else behaves like a real miss (exit 1)
      for v in ${MOCK_DOCKER_VOLUMES:-}; do
        [[ "$v" == "$3" ]] && exit 0
      done
      exit 1
      ;;
    rm)
      exit "${MOCK_DOCKER_VOLUME_RM_EXIT:-0}"
      ;;
  esac
fi

exit 0
