#!/usr/bin/env bash
# fake `gh` CLI for tests — logs every invocation and answers the
# subcommands dco actually shells out to, controlled via MOCK_GH_* env vars
set -euo pipefail

echo "gh $*" >> "${MOCK_LOG:-/dev/null}"

case "$1 $2" in
  "repo create")
    exit "${MOCK_GH_REPO_CREATE_EXIT:-0}"
    ;;
  "repo view")
    # unset MOCK_GH_REPO_VIEW_NAME_WITH_OWNER == "no such repo" (exit 1,
    # matching real gh when the name doesn't exist under this account)
    [[ -n "${MOCK_GH_REPO_VIEW_NAME_WITH_OWNER:-}" ]] || exit 1
    printf '%s\t%s\n' "$MOCK_GH_REPO_VIEW_NAME_WITH_OWNER" "${MOCK_GH_REPO_VIEW_SSH_URL:-}"
    ;;
  "api user")
    [[ -n "${MOCK_GH_HANDLE:-}" ]] && printf '%s\n' "${MOCK_GH_HANDLE}"
    exit "${MOCK_GH_API_EXIT:-0}"
    ;;
  "label create")
    exit "${MOCK_GH_LABEL_CREATE_EXIT:-0}"
    ;;
esac
exit 0
