#!/usr/bin/env bash
# dco — Dev Container Open
# Usage:
#   dco                              # shell in /workspace in CWD's container
#   dco /path/to/project             # shell in /workspace in specific project
#   dco . gpu-trading                # named sub-config in CWD
#   dco /path/to/project name        # named sub-config in project
#   dco --claude                     # open CWD's container, attach/create tmux 'claude' session
#   dco /path/to/project --claude    # same, in a specific project
#                                    # (detach with Ctrl-b d; rerun --claude to reattach)
#   dco --rebuild                    # force rebuild before attaching
#   dco --stop [path]                # stop/remove a project's container
#   dco --list                       # list running devcontainers
#   dco --regen [path]               # refresh .devcontainer/ from latest templates
#   dco . autonomous --dsp           # unattended Claude, GitHub-issue-driven (see README)

set -euo pipefail

SHAREDIR="@SHAREDIR@"

# ── helpers ──────────────────────────────────────────────────────────────────
die()  { echo "dco: error: $*" >&2; exit 1; }
info() { echo "dco: $*" >&2; }

# copies the latest templates/+config/ into <dest>, overwriting any
# top-level files but leaving named sub-configs (<dest>/<name>/) alone
scaffold_devcontainer() {
  local dest="$1"
  [[ -d "$SHAREDIR/templates" ]] || \
    die "template dir not found: $SHAREDIR/templates — run 'make install', don't execute dco.in directly"
  [[ -f "$SHAREDIR/config/allowlist.txt" ]] || \
    die "config not found: $SHAREDIR/config/allowlist.txt — run 'make install', don't execute dco.in directly"
  mkdir -p "$dest"
  cp -r "$SHAREDIR/templates/." "$dest/"
  cp "$SHAREDIR/config/allowlist.txt" "$dest/allowlist.txt"
  chmod +x "$dest/init-firewall.sh"
}

# scaffolds a named sub-config profile (e.g. "autonomous") from
# $SHAREDIR/templates/<name>/ into <dest>, if such a shipped profile exists.
# Returns 1 (no die) if no shipped profile by that name exists, so callers
# can fall back to their own "not found" handling. Substitutes
# DCO_GITHUB_HANDLE into a scaffolded CLAUDE.md's {{DCO_GITHUB_HANDLE}}
# placeholder when that env var is set.
scaffold_named_subconfig() {
  local name="$1" dest="$2"
  local src="$SHAREDIR/templates/$name"
  [[ -d "$src" ]] || return 1
  mkdir -p "$dest"
  cp -r "$src/." "$dest/"
  [[ -f "$dest/init-firewall.sh" ]] && chmod +x "$dest/init-firewall.sh"
  if [[ -f "$dest/CLAUDE.md" && -n "${DCO_GITHUB_HANDLE:-}" ]]; then
    sed -i.bak "s/{{DCO_GITHUB_HANDLE}}/${DCO_GITHUB_HANDLE//\//\\/}/g" "$dest/CLAUDE.md"
    rm -f "$dest/CLAUDE.md.bak"
  fi
  return 0
}

# ── help ─────────────────────────────────────────────────────────────────────
usage() {
  cat >&2 <<'EOF'
dco — Dev Container Open

Usage:
  dco [path] [sub-config] [flags]

Arguments:
  path          Project directory (default: current directory)
  sub-config    Named config under .devcontainer/<name>/devcontainer.json

Flags:
  -c, --claude    Launch Claude Code in a persistent tmux session ('claude')
  -r, --rebuild   Force rebuild (removes existing container first)
  -s, --stop      Stop and remove the project's container
  -g, --regen     Refresh a project's .devcontainer/ from the latest templates
      --dsp       Launch Claude with --dangerously-skip-permissions (implies --claude)
  -l, --list      List all running devcontainers
  -h, --help      Show this help

--claude runs Claude inside "tmux new-session -A -s claude", so it
attaches to an already-running session if one exists, or creates one.
Detach with Ctrl-b then d — Claude keeps running in the container.
Rerun `dco --claude` (same project) later to reattach to it.

--dsp runs Claude fully unattended, no tool-use prompts at all. Refuses
to launch unless the resolved config's allowlist.txt is actually
enforcing the firewall and DCO_GITHUB_TOKEN is set — see the README's
Autonomous mode section before using this.

Examples:
  dco                              # shell in CWD's container
  dco ~/projects/trading           # shell in specific project
  dco . gpu-trading                # named sub-config in CWD
  dco --claude                     # attach/create tmux session running Claude
  dco --rebuild --claude           # rebuild then launch Claude
  dco --stop ~/projects/trading    # remove that project's container
  dco --regen ~/projects/trading   # refresh that project's .devcontainer/ from templates
  dco . autonomous --dsp           # unattended Claude, GitHub-issue-driven
  dco --list                       # show all running devcontainers

Shell function (add to .zshrc):
  cdco() { cd "$1" && dco "${@:2}"; }
EOF
  exit 0
}

# ── args ─────────────────────────────────────────────────────────────────────
LAUNCH_CLAUDE=false
REBUILD=false
STOP=false
REGEN=false
DSP=false
LIST=false
POSITIONAL=()
for arg in "$@"; do
  case "$arg" in
    --claude|-c)  LAUNCH_CLAUDE=true ;;
    --rebuild|-r) REBUILD=true ;;
    --stop|-s)    STOP=true ;;
    --regen|-g)   REGEN=true ;;
    --dsp)        DSP=true; LAUNCH_CLAUDE=true ;;
    --list|-l)    LIST=true ;;
    --help|-h)    usage ;;
    *) POSITIONAL+=("$arg") ;;
  esac
done

# ── list mode ─────────────────────────────────────────────────────────────────
if $LIST; then
  docker ps \
    --filter "label=devcontainer.local_folder" \
    --format "table {{.Names}}\t{{.Status}}\t{{.Label \"devcontainer.local_folder\"}}"
  exit 0
fi

WORKSPACE="${POSITIONAL[0]:-$(pwd)}"
SUB_CONFIG="${POSITIONAL[1]:-}"
WORKSPACE="$(realpath "$WORKSPACE")"

[[ -d "$WORKSPACE" ]] || die "not a directory: $WORKSPACE"

# unique-per-path-and-sub-config id for this project's named volumes
# (bash-history, Claude config/memory) — derived from the full path (not
# just the folder name) plus the sub-config name, so two differently-located
# projects that share a directory name (e.g. two unrelated "api" checkouts)
# never collide, and each named sub-config (e.g. "autonomous") for the same
# project gets its own private volume instead of sharing the default one
if command -v sha256sum &>/dev/null; then
  WORKSPACE_HASH="$(printf '%s' "$WORKSPACE" | sha256sum | cut -c1-8)"
else
  WORKSPACE_HASH="$(printf '%s' "$WORKSPACE" | shasum -a 256 | cut -c1-8)"
fi
WORKSPACE_SLUG="$(basename "$WORKSPACE" | tr -c 'a-zA-Z0-9_.-' '-')"
DCO_PROJECT_ID="${WORKSPACE_SLUG}-${WORKSPACE_HASH}"
if [[ -n "$SUB_CONFIG" ]]; then
  SUB_CONFIG_SLUG="$(basename "$SUB_CONFIG" | tr -c 'a-zA-Z0-9_.-' '-')"
  DCO_PROJECT_ID="${DCO_PROJECT_ID}-${SUB_CONFIG_SLUG}"
fi
export DCO_PROJECT_ID

# ── stop mode ─────────────────────────────────────────────────────────────────
if $STOP; then
  CONTAINER=$(docker ps -q --filter "label=devcontainer.local_folder=$WORKSPACE")
  if [[ -z "$CONTAINER" ]]; then
    # also check stopped containers
    CONTAINER=$(docker ps -aq --filter "label=devcontainer.local_folder=$WORKSPACE")
  fi
  [[ -n "$CONTAINER" ]] || die "no container found for $WORKSPACE"
  info "removing container for $WORKSPACE ..."
  docker rm -f "$CONTAINER"
  info "done."
  exit 0
fi

# ── regen mode ────────────────────────────────────────────────────────────────
if $REGEN; then
  DEST="$WORKSPACE/.devcontainer"
  if [[ -d "$DEST" ]]; then
    info "regenerating $DEST from $SHAREDIR/templates ..."
    if [[ -d "$WORKSPACE/.git" ]]; then
      info "(git repo detected — run 'git diff .devcontainer' after to review changes)"
    else
      info "warning: $WORKSPACE is not a git repo — existing .devcontainer/ files will be overwritten with no backup"
    fi
  else
    info "no existing .devcontainer/ — creating one in $WORKSPACE"
  fi
  scaffold_devcontainer "$DEST"
  info "done. Named sub-configs under .devcontainer/<name>/ are untouched. Run 'dco --rebuild' to apply."
  exit 0
fi

# ── find config ───────────────────────────────────────────────────────────────
if [[ -n "$SUB_CONFIG" ]]; then
  CONFIG="$WORKSPACE/.devcontainer/$SUB_CONFIG/devcontainer.json"
  if [[ ! -f "$CONFIG" ]]; then
    DEST="$WORKSPACE/.devcontainer/$SUB_CONFIG"
    if scaffold_named_subconfig "$SUB_CONFIG" "$DEST"; then
      info "no .devcontainer/$SUB_CONFIG found — scaffolded from the shipped '$SUB_CONFIG' profile"
    else
      SHIPPED=("$SHAREDIR"/templates/*/)
      if [[ -d "${SHIPPED[0]:-}" ]]; then
        NAMES=()
        for d in "${SHIPPED[@]}"; do NAMES+=("$(basename "$d")"); done
        die "no .devcontainer/$SUB_CONFIG found, and no shipped profile named '$SUB_CONFIG' exists. Available shipped profiles: ${NAMES[*]}"
      else
        die "no .devcontainer/$SUB_CONFIG found, and no shipped named profiles are available"
      fi
    fi
  fi
elif [[ -f "$WORKSPACE/.devcontainer.json" ]]; then
  CONFIG="$WORKSPACE/.devcontainer.json"
elif [[ -f "$WORKSPACE/.devcontainer/devcontainer.json" ]]; then
  CONFIG="$WORKSPACE/.devcontainer/devcontainer.json"
else
  # list available configs if multiple exist
  CONFIGS=("$WORKSPACE"/.devcontainer/*/devcontainer.json)
  if [[ ${#CONFIGS[@]} -eq 1 && -f "${CONFIGS[0]}" ]]; then
    CONFIG="${CONFIGS[0]}"
  elif [[ ${#CONFIGS[@]} -gt 1 ]]; then
    echo "dco: multiple configs found — pick one:" >&2
    for c in "${CONFIGS[@]}"; do
      name="$(basename "$(dirname "$c")")"
      echo "  dco $(basename "$WORKSPACE") $name" >&2
    done
    exit 1
  else
    info "no devcontainer.json found — creating default .devcontainer in $WORKSPACE"
    DEST="$WORKSPACE/.devcontainer"
    scaffold_devcontainer "$DEST"

    CONFIG="$DEST/devcontainer.json"
    info "created $CONFIG (Claude Code Sandbox)"
  fi
fi

[[ -f "$CONFIG" ]] || die "config not found: $CONFIG"
info "using config: ${CONFIG#"$WORKSPACE/"}"

# ── autonomous-mode guardrails ────────────────────────────────────────────────
if $DSP; then
  ALLOWLIST_FILE="$(dirname "$CONFIG")/allowlist.txt"
  ALLOWLIST_COUNT=0
  if [[ -f "$ALLOWLIST_FILE" ]]; then
    ALLOWLIST_COUNT="$(grep -vcE '^[[:space:]]*(#|$)' "$ALLOWLIST_FILE" 2>/dev/null || true)"
    ALLOWLIST_COUNT="${ALLOWLIST_COUNT:-0}"
  fi
  if [[ "$ALLOWLIST_COUNT" -eq 0 ]]; then
    die "--dsp refuses to launch: $ALLOWLIST_FILE has no active entries, so the
  container firewall would be a complete no-op — Claude would run with
  --dangerously-skip-permissions AND unrestricted network egress at the same
  time. Add at least one domain to that file before retrying."
  fi
  [[ -n "${DCO_GITHUB_TOKEN:-}" ]] || die "--dsp refuses to launch: DCO_GITHUB_TOKEN is not set. Autonomous mode
  is GitHub-issue-driven and needs a fine-grained PAT — see the README's
  Autonomous mode section for setup."
fi

# ── ensure devcontainer CLI ───────────────────────────────────────────────────
if ! command -v devcontainer &>/dev/null; then
  die "@devcontainers/cli not found. Install it with:
  npm install -g @devcontainers/cli
  (requires Node >=20 — use fnm: https://github.com/Schniz/fnm)"
fi

# ── bring up the container ────────────────────────────────────────────────────
info "starting container for $WORKSPACE ..."
UP_ARGS=()
$REBUILD && UP_ARGS+=(--remove-existing-container)
devcontainer up \
  --workspace-folder "$WORKSPACE" \
  --config "$CONFIG" \
  "${UP_ARGS[@]}"

# ── sync git identity from host ───────────────────────────────────────────────
# container filesystem isn't persisted across rebuilds, so re-sync every launch
GIT_NAME="$(git config --global user.name 2>/dev/null || true)"
GIT_EMAIL="$(git config --global user.email 2>/dev/null || true)"
[[ -n "$GIT_NAME" ]] && devcontainer exec --workspace-folder "$WORKSPACE" --config "$CONFIG" \
  -- git config --global user.name "$GIT_NAME" &>/dev/null
[[ -n "$GIT_EMAIL" ]] && devcontainer exec --workspace-folder "$WORKSPACE" --config "$CONFIG" \
  -- git config --global user.email "$GIT_EMAIL" &>/dev/null

# ── exec in ───────────────────────────────────────────────────────────────────
SHELL_CMD="bash"
CLAUDE_CMD="claude"
if $DSP; then
  CLAUDE_CMD="claude --dangerously-skip-permissions"
  info "autonomous mode: firewall enforcing, GH_TOKEN set, PR-only workflow, guardrail hook active — launching with --dangerously-skip-permissions"
fi

if $LAUNCH_CLAUDE; then
  info "attaching to tmux session 'claude' (creating it if needed; detach with Ctrl-b d)..."
  exec devcontainer exec \
    --workspace-folder "$WORKSPACE" \
    --config "$CONFIG" \
    -- "$SHELL_CMD" -lc "tmux new-session -A -s claude $CLAUDE_CMD"
else
  info "attaching shell ($SHELL_CMD) in /workspace..."
  exec devcontainer exec \
    --workspace-folder "$WORKSPACE" \
    --config "$CONFIG" \
    -- "$SHELL_CMD" -l
fi
