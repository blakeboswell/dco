#!/usr/bin/env bash
# dco — Dev Container Open
# Usage:
#   dco                              # shell in /workspace in CWD's container
#   dco /path/to/project             # shell in /workspace in specific project
#   dco --sub-config gpu-trading     # named sub-config in CWD
#   dco /path/to/project --sub-config name  # named sub-config in project
#   dco --claude                     # open CWD's container, attach/create tmux 'claude' session
#   dco /path/to/project --claude    # same, in a specific project
#                                    # (detach with Ctrl-b d; rerun --claude to reattach)
#   dco --rebuild                    # force rebuild before attaching
#   dco --stop [path]                # stop/remove a project's container
#   dco --purge [path]               # stop + also delete its volumes (bash history, Claude memory)
#   dco --list                       # list running devcontainers
#   dco --regen [path]               # refresh .devcontainer/ from latest templates

set -euo pipefail

SHAREDIR="@SHAREDIR@"

# ── helpers ──────────────────────────────────────────────────────────────────
die()  { echo "dco: error: $*" >&2; exit 1; }
info() { echo "dco: $*" >&2; }

# copies the latest templates/+config/ into <dest>, overwriting any
# top-level files but leaving named sub-configs (<dest>/<name>/) alone —
# dco doesn't ship any of its own, but a project can commit its own
# .devcontainer/<name>/ directory, and `cp -r templates/.` would otherwise
# recurse into it and clobber a hand-written file with the stock top-level
# one, so only top-level files are copied here.
scaffold_devcontainer() {
  local dest="$1" entry
  [[ -d "$SHAREDIR/templates" ]] || \
    die "template dir not found: $SHAREDIR/templates — run 'make install', don't execute dco.in directly"
  [[ -f "$SHAREDIR/config/allowlist.txt" ]] || \
    die "config not found: $SHAREDIR/config/allowlist.txt — run 'make install', don't execute dco.in directly"
  mkdir -p "$dest"
  for entry in "$SHAREDIR"/templates/*; do
    [[ -d "$entry" ]] && continue
    cp "$entry" "$dest/"
  done
  cp "$SHAREDIR/config/allowlist.txt" "$dest/allowlist.txt"
  chmod +x "$dest/init-firewall.sh"
}

# replaces every character of $1 outside the $2 character class with '-'.
# Deliberately takes a plain string rather than piping a command's output
# through `tr -c ... '-'`: tr -c also complements the trailing newline that
# command output carries mid-pipe, turning it into a literal '-' before the
# outer $(...) ever gets a chance to strip it — always leave any command
# substitution ($(...)) on the outside of this call, never the inside.
slugify() { printf '%s' "${1//[^$2]/-}"; }

# unique-per-path-and-sub-config id for a project's named volumes
# (bash-history, Claude config/memory) — derived from the full path (not
# just the folder name) plus the sub-config name, so two differently-located
# projects that share a directory name (e.g. two unrelated "api" checkouts)
# never collide, and each named sub-config for the same project gets its
# own private volume instead of sharing the default one
project_id() {
  local workspace="$1" sub_config="${2:-}" hash slug id
  if command -v sha256sum &>/dev/null; then
    hash="$(printf '%s' "$workspace" | sha256sum | cut -c1-8)"
  else
    hash="$(printf '%s' "$workspace" | shasum -a 256 | cut -c1-8)"
  fi
  slug="$(slugify "$(basename "$workspace")" 'a-zA-Z0-9_.-')"
  id="${slug}-${hash}"
  if [[ -n "$sub_config" ]]; then
    id="${id}-$(slugify "$(basename "$sub_config")" 'a-zA-Z0-9_.-')"
  fi
  printf '%s' "$id"
}

# ── help ─────────────────────────────────────────────────────────────────────
usage() {
  cat >&2 <<'EOF'
dco — Dev Container Open

Usage:
  dco [path] [flags]

Arguments:
  path          Project directory (default: current directory)

Flags:
  -c, --claude    Launch Claude Code in a persistent tmux session ('claude')
  -r, --rebuild   Force rebuild (removes existing container first)
  -s, --stop      Stop and remove the project's container
      --purge     Like --stop, but also delete its volumes (bash history,
                  Claude's memory) — irreversible, always confirms first
  -g, --regen     Refresh a project's .devcontainer/ from the latest templates
      --sub-config <name>
                  Use .devcontainer/<name>/devcontainer.json instead of the
                  default profile. If your project has committed its own
                  template under .devcontainer/<name>/, that's used as-is;
                  dco itself ships no named profiles to scaffold
      --up-only   Bring the container up (volumes, git identity synced) and
                  exit, without attaching. For headless callers that drive
                  their own `devcontainer exec` afterward. Mutually
                  exclusive with --claude
  -l, --list      List all running devcontainers
  -h, --help      Show this help

--claude runs Claude inside "tmux new-session -A -s claude", so it
attaches to an already-running session if one exists, or creates one.
Detach with Ctrl-b then d — Claude keeps running in the container.
Rerun `dco --claude` (same project) later to reattach to it.

Examples:
  dco                              # shell in CWD's container
  dco ~/projects/trading           # shell in specific project
  dco --sub-config gpu-trading     # named sub-config in CWD
  dco --claude                     # attach/create tmux session running Claude
  dco --rebuild --claude           # rebuild then launch Claude
  dco --stop ~/projects/trading    # remove that project's container
  dco --purge ~/projects/trading   # also delete its volumes (irreversible)
  dco --regen ~/projects/trading   # refresh that project's .devcontainer/ from templates
  dco --list                       # show all running devcontainers
  dco --sub-config eigen --up-only # bring up a headless-driven container, don't attach

Shell function (add to .zshrc):
  cdco() { cd "$1" && dco "${@:2}"; }
EOF
  exit 0
}

# wraps everything below so the script can be sourced (e.g. by the test
# suite) without running any of it — see the sourcing guard at the bottom.
# Re-asserts strict mode in case main() is invoked after sourcing reset it
# (the test suite's source_dco helper does this on purpose, to avoid
# leaking set -euo pipefail into the rest of the test process).
main() {
set -euo pipefail

# ── args ─────────────────────────────────────────────────────────────────────
LAUNCH_CLAUDE=false
REBUILD=false
STOP=false
PURGE=false
REGEN=false
LIST=false
UP_ONLY=false
SUB_CONFIG=""
POSITIONAL=()
while [[ $# -gt 0 ]]; do
  case "$1" in
    --claude|-c)  LAUNCH_CLAUDE=true ;;
    --rebuild|-r) REBUILD=true ;;
    --stop|-s)    STOP=true ;;
    --purge)      PURGE=true ;;
    --regen|-g)   REGEN=true ;;
    --list|-l)    LIST=true ;;
    --up-only)    UP_ONLY=true ;;
    --sub-config)
      [[ $# -ge 2 ]] || die "--sub-config needs a value, e.g. --sub-config gpu-trading"
      SUB_CONFIG="$2"
      shift
      ;;
    --help|-h)    usage ;;
    *) POSITIONAL+=("$1") ;;
  esac
  shift
done

$UP_ONLY && $LAUNCH_CLAUDE && die "--up-only and --claude are mutually exclusive"

# ── list mode ─────────────────────────────────────────────────────────────────
if $LIST; then
  docker ps \
    --filter "label=devcontainer.local_folder" \
    --format "table {{.Names}}\t{{.Status}}\t{{.Label \"devcontainer.local_folder\"}}"
  exit 0
fi

[[ ${#POSITIONAL[@]} -le 1 ]] || \
  die "too many arguments: ${POSITIONAL[*]:1} — sub-configs are now selected with
  --sub-config <name>, not a second positional argument."

WORKSPACE="${POSITIONAL[0]:-$(pwd)}"
WORKSPACE="$(realpath "$WORKSPACE")"

[[ -d "$WORKSPACE" ]] || die "not a directory: $WORKSPACE"

DCO_PROJECT_ID="$(project_id "$WORKSPACE" "$SUB_CONFIG")"
export DCO_PROJECT_ID

# ── stop mode ─────────────────────────────────────────────────────────────────
if $STOP; then
  CONTAINER=$(docker ps -q --filter "label=devcontainer.local_folder=$WORKSPACE")
  if [[ -z "$CONTAINER" ]]; then
    # also check stopped containers
    CONTAINER=$(docker ps -aq --filter "label=devcontainer.local_folder=$WORKSPACE")
  fi
  [[ -n "$CONTAINER" ]] || die "no container found for $WORKSPACE"
  info "removing container for $WORKSPACE ..."
  docker rm -f "$CONTAINER"
  info "done."
  exit 0
fi

# ── purge mode ────────────────────────────────────────────────────────────────
# --stop's more destructive sibling: also removes the two named volumes
# (bash history, Claude's config/memory) that --stop and --rebuild
# deliberately leave alone. Irreversible, so it always confirms first,
# and it's fine for either the container or the volumes to already be
# gone (e.g. after a prior --stop) — it just removes whatever it finds.
if $PURGE; then
  CONTAINER=$(docker ps -q --filter "label=devcontainer.local_folder=$WORKSPACE")
  if [[ -z "$CONTAINER" ]]; then
    CONTAINER=$(docker ps -aq --filter "label=devcontainer.local_folder=$WORKSPACE")
  fi

  VOLUMES=()
  for v in "claude-code-bashhistory-$DCO_PROJECT_ID" "claude-code-config-$DCO_PROJECT_ID"; do
    docker volume inspect "$v" &>/dev/null && VOLUMES+=("$v")
  done

  if [[ -z "$CONTAINER" && ${#VOLUMES[@]} -eq 0 ]]; then
    info "nothing to purge for $WORKSPACE (no container or volumes found)"
    exit 0
  fi

  info "this will permanently remove, for $WORKSPACE:"
  [[ -n "$CONTAINER" ]] && info "  - container $CONTAINER"
  for v in "${VOLUMES[@]}"; do info "  - volume $v (irreversible — this is where Claude's memory for this project lives)"; done
  REPLY=""
  read -r -p "dco: continue? [y/N] " REPLY || true
  [[ "$REPLY" =~ ^[Yy]$ ]] || die "purge aborted."

  [[ -n "$CONTAINER" ]] && { info "removing container ..."; docker rm -f "$CONTAINER" &>/dev/null; }
  for v in "${VOLUMES[@]}"; do
    info "removing volume $v ..."
    docker volume rm "$v" &>/dev/null
  done
  info "done."
  exit 0
fi

# ── regen mode ────────────────────────────────────────────────────────────────
if $REGEN; then
  DEST="$WORKSPACE/.devcontainer"
  if [[ -d "$DEST" ]]; then
    info "regenerating $DEST from $SHAREDIR/templates ..."
    if [[ -d "$WORKSPACE/.git" ]]; then
      info "(git repo detected — run 'git diff .devcontainer' after to review changes)"
    else
      info "warning: $WORKSPACE is not a git repo — existing .devcontainer/ files will be overwritten with no backup"
    fi
  else
    info "no existing .devcontainer/ — creating one in $WORKSPACE"
  fi
  scaffold_devcontainer "$DEST"
  info "done. Named sub-configs under .devcontainer/<name>/ are untouched. Run 'dco --rebuild' to apply."
  exit 0
fi

# ── find config ───────────────────────────────────────────────────────────────
if [[ -n "$SUB_CONFIG" ]]; then
  # a sub-config can point "dockerfile" at the shared top-level ../Dockerfile
  # (dco's own templates do). Checked every time a sub-config is used, not
  # just when scaffolding it: a workspace can be left with
  # .devcontainer/<name>/ already present but the shared files still
  # missing, and that workspace would otherwise stay broken forever, since
  # the sub-config's own devcontainer.json already existing skips past the
  # scaffold branch below entirely. Self-heals instead of requiring
  # `dco --regen` by hand. Never touches an existing top-level
  # devcontainer.json/Dockerfile.
  if [[ ! -f "$WORKSPACE/.devcontainer/devcontainer.json" ]]; then
    info "no .devcontainer/devcontainer.json found — scaffolding the shared top-level files sub-configs may depend on"
    scaffold_devcontainer "$WORKSPACE/.devcontainer"
  fi

  CONFIG="$WORKSPACE/.devcontainer/$SUB_CONFIG/devcontainer.json"
  [[ -f "$CONFIG" ]] || \
    die "no .devcontainer/$SUB_CONFIG/devcontainer.json found. dco ships no named
  profiles to scaffold — commit your own .devcontainer/$SUB_CONFIG/devcontainer.json
  first (it can share the top-level Dockerfile via \"dockerfile\": \"../Dockerfile\",
  the way the default profile's own Dockerfile is laid out)."
elif [[ -f "$WORKSPACE/.devcontainer.json" ]]; then
  CONFIG="$WORKSPACE/.devcontainer.json"
elif [[ -f "$WORKSPACE/.devcontainer/devcontainer.json" ]]; then
  CONFIG="$WORKSPACE/.devcontainer/devcontainer.json"
else
  # no default profile yet and no --sub-config given: fall through to
  # scaffolding the default. If other named sub-configs already exist,
  # surface them first — plain `dco` always means "the default profile,"
  # but a project that's only ever used a named sub-config on this
  # workspace shouldn't leave that fact invisible.
  OTHER_SUBCONFIGS=("$WORKSPACE"/.devcontainer/*/devcontainer.json)
  if [[ -f "${OTHER_SUBCONFIGS[0]:-}" ]]; then
    NAMES=()
    for c in "${OTHER_SUBCONFIGS[@]}"; do NAMES+=("$(basename "$(dirname "$c")")"); done
    info "this project also has sub-config(s) here: ${NAMES[*]} (use --sub-config <name> to use one instead)"
  fi
  info "no devcontainer.json found — creating default .devcontainer in $WORKSPACE"
  DEST="$WORKSPACE/.devcontainer"
  scaffold_devcontainer "$DEST"

  CONFIG="$DEST/devcontainer.json"
  info "created $CONFIG (Claude Code Sandbox)"
fi

[[ -f "$CONFIG" ]] || die "config not found: $CONFIG"
info "using config: ${CONFIG#"$WORKSPACE/"}"

# ── ensure devcontainer CLI ───────────────────────────────────────────────────
if ! command -v devcontainer &>/dev/null; then
  die "@devcontainers/cli not found. Install it with:
  npm install -g @devcontainers/cli
  (requires Node >=20 — use fnm: https://github.com/Schniz/fnm)"
fi

# ── bring up the container ────────────────────────────────────────────────────
info "starting container for $WORKSPACE ..."
UP_ARGS=()
$REBUILD && UP_ARGS+=(--remove-existing-container)
devcontainer up \
  --workspace-folder "$WORKSPACE" \
  --config "$CONFIG" \
  "${UP_ARGS[@]}"

# ── sync git identity from host ───────────────────────────────────────────────
# container filesystem isn't persisted across rebuilds, so re-sync every
# launch. Deliberately `git -C "$WORKSPACE" config` rather than
# `--global`: git's own resolution checks the workspace's local config
# before falling back to the host's global one, so this defaults to your
# host identity but is overridable per-project the normal git way --
# `git -C /path/to/project config user.name "..."` (no --global) on the
# host, no dco-specific mechanism needed. Works the same whether or not
# $WORKSPACE is a git repo yet; falls straight through to global either way.
GIT_NAME="$(git -C "$WORKSPACE" config user.name 2>/dev/null || true)"
GIT_EMAIL="$(git -C "$WORKSPACE" config user.email 2>/dev/null || true)"
[[ -n "$GIT_NAME" ]] && devcontainer exec --workspace-folder "$WORKSPACE" --config "$CONFIG" \
  -- git config --global user.name "$GIT_NAME" &>/dev/null
[[ -n "$GIT_EMAIL" ]] && devcontainer exec --workspace-folder "$WORKSPACE" --config "$CONFIG" \
  -- git config --global user.email "$GIT_EMAIL" &>/dev/null

# ── up-only: return control instead of attaching ──────────────────────────────
# for callers driving the container headlessly (e.g. Eigen's autonomous loop)
# that want it up, with volumes/git identity resolved, but no interactive
# shell attached — they run their own `devcontainer exec` per turn afterward.
if $UP_ONLY; then
  info "container ready for $WORKSPACE (up-only, not attaching)"
  exit 0
fi

# ── exec in ───────────────────────────────────────────────────────────────────
SHELL_CMD="bash"
CLAUDE_CMD="claude"

if $LAUNCH_CLAUDE; then
  info "attaching to tmux session 'claude' (creating it if needed; detach with Ctrl-b d)..."
  exec devcontainer exec \
    --workspace-folder "$WORKSPACE" \
    --config "$CONFIG" \
    -- "$SHELL_CMD" -lc "tmux new-session -A -s claude $CLAUDE_CMD"
else
  info "attaching shell ($SHELL_CMD) in /workspace..."
  exec devcontainer exec \
    --workspace-folder "$WORKSPACE" \
    --config "$CONFIG" \
    -- "$SHELL_CMD" -l
fi

}

# only run main when executed directly (e.g. as the installed $BINDIR/dco);
# a plain `source dco.in` (as the test suite does) just defines the
# functions above and returns, so tests can call them individually
if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
  main "$@"
fi
